# Supabase client settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only Supabase service role key. Never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Accounting integration API bearer token
ACCOUNTING_API_KEY=replace-with-a-long-random-token

# Web Push public key used by the notification UI
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
